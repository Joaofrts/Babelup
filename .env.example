# Docker Compose Environment Variables
# Copy this file to .env and update with your secure credentials
# WARNING: Never commit actual credentials to the repository

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_secure_password_here
MYSQL_DATABASE=Babelup

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/Babelup?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# Security Configuration
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=your_secure_password_here
API_SECURITY_TOKEN_SECRET=your_super_secret_jwt_key_here_min_32_chars
